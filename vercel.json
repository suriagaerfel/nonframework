{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/articles",
      "dest": "/api/articles.php"
    },

    {
      "src": "/teacher-files",
      "dest": "/api/teacher-files.php"
    },

    {
      "src": "/tools",
      "dest": "/api/tools.php"
    },

    {
      "src": "/researches",
      "dest": "/api/researches.php"
    },

    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
